# 模型文件（通常很大，不应提交到 git）
*.safetensors
*.bin
*.pt
*.pth
*.ckpt

# 模型权重目录：忽略内容，但保留目录说明
models/**
!models/
!models/README.md

# 评估结果：忽略内容，但保留目录说明
eval_results/**
!eval_results/
!eval_results/README.md

# 长任务日志：忽略内容，但保留目录说明
logs/**
!logs/
!logs/README.md

# 训练产物临时目录
